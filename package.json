{
	"name": "antigravity-skills-editor",
	"displayName": "Ultra Skills Editor",
	"description": "A beautifully crafted, multi-language skills management extension for VS Code, Cursor, Trae (Global & CN), Windsurf, Antigravity, Qoder, and CodeBuddy. Create, edit, and organize AI skills.",
	"publisher": "Michael-IT001",
	"version": "2.8.8",
	"icon": "media/icon.png",
	"engines": {
		"vscode": "^1.60.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"ultra",
		"skills",
		"ai",
		"editor",
		"multi-language",
		"markdown",
		"preview",
		"template"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCommand:antigravity-skills-editor.openSkillsEditor",
		"onCommand:antigravity-skills-editor.importSkillFromExplorer",
		"onCommand:antigravity-skills-editor.exportSkill",
		"*"
	],
	"main": "./src/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "antigravity-skills-editor.openSkillsEditor",
				"title": "Open My Skills / 打开我的技能"
			},
			{
				"command": "antigravity-skills-editor.importSkillFromExplorer",
				"title": "Import as Skill / 导入为技能"
			},
			{
				"command": "antigravity-skills-editor.exportSkill",
				"title": "Export Current Skill"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "antigravity-skills-editor.importSkillFromExplorer",
					"group": "7_modification",
					"when": "resourceExtname == '.md' || resourceExtname == '.mdc' || explorerResourceIsFolder"
				}
			]
		},
		"keybindings": [
			{
				"command": "antigravity-skills-editor.openSkillsEditor",
				"key": "ctrl+shift+k",
				"mac": "cmd+shift+k"
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Michael-IT001/antigravity-skills-editor"
	},
	"license": "MIT",
	"galleryBanner": {
		"color": "#1E1E2E",
		"theme": "dark"
	},
	"__metadata": {
		"installedTimestamp": 1774300368370,
		"targetPlatform": "universal",
		"size": 570724
	}
}